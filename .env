# ===========================================
# Docker MariaDB Configuration
# ===========================================
# Root password for MariaDB
MYSQL_ROOT_PASSWORD=root_password
# Application user credentials
MYSQL_USER=dep_user
MYSQL_PASSWORD=dep_password

# ===========================================
# Landlord Database (Master Database)
# ===========================================
# The master database stores tenant and domain
# configuration for the multi-tenant system
LANDLORD_DB_HOST=localhost
LANDLORD_DB_PORT=3307
LANDLORD_DB_NAME=landlord_db
LANDLORD_DB_USER=dep_user
      LANDLORD_DB_PASSWORD=asdlakjfdqowfijda

# ===========================================
# Admin API Configuration
# ===========================================
# The admin API is the "landlord" application
# used to manage tenants and domains
PORT=3000
NODE_ENV=development

# ===========================================
# JWT Authentication
# ===========================================
# Secret key for signing JWT tokens
# IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ===========================================
# Client API Configuration (Multi-tenant)
# ===========================================
# The client API resolves tenant databases
# based on the incoming request domain
CLIENT_API_PORT=3001

# ===========================================
# Tenant Database Template (for migrations)
# ===========================================
# Used when running drizzle-kit for tenant schema
# This is a template database used to generate
# migrations that will be applied to all tenant DBs
TENANT_DB_HOST=localhost
TENANT_DB_PORT=3307
TENANT_DB_NAME=tenant_template_db
TENANT_DB_USER=dep_user
TENANT_DB_PASSWORD=dep_password

# ===========================================
# Encryption Configuration
# ===========================================
# Encryption keys for sensitive data at rest
# Format: v1:hex_key,v2:hex_key (comma-separated, versioned)
# The first key is used for encryption, all keys are tried for decryption
# Generate new keys with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Never remove old keys until all data is re-encrypted with new keys!
ENCRYPTION_KEYS=v1:00ce8feed15e8c6867377f245c82d4a721eb6580a02afcce1d24e305345ba6d9

